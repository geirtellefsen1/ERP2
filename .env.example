# ============================================================
# BPO Nexus — Environment Variables
# Copy this to .env and fill in real values
# NEVER commit .env to git
# ============================================================

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/bpo_nexus
POSTGRES_PASSWORD=postgres

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth0 — BPO agency auth
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your_client_id_here
AUTH0_CLIENT_SECRET=your_client_secret_here
AUTH0_AUDIENCE=https://api.bponexus.com

# Claude AI (Anthropic)
CLAUDE_API_KEY=sk-ant-...

# DigitalOcean Spaces (S3-compatible file storage)
DO_SPACES_KEY=your_spaces_key
DO_SPACES_SECRET=your_spaces_secret
DO_SPACES_ENDPOINT=https://cap-1.digitaloceanspaces.com
DO_SPACES_BUCKET=bpo-nexus-files

# Open Banking
TRUELAYER_CLIENT_ID=your_truelayer_id
TRUELAYER_CLIENT_SECRET=your_truelayer_secret

# Twilio (WhatsApp via OpenClaw)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token

# Email (Resend)
RESEND_API_KEY=re_your_resend_key

# App
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# AWS Textract (document OCR)
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_REGION=eu-west-1
