# ============================================================
# BPO Nexus — Environment Variables
# Copy this to .env and fill in real values
# NEVER commit .env to git
# ============================================================

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/bpo_nexus
POSTGRES_PASSWORD=postgres

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT (local auth — refresh-token rotation)
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256

# Auth0 — BPO agency auth
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your_client_id_here
AUTH0_CLIENT_SECRET=your_client_secret_here
AUTH0_AUDIENCE=https://api.bponexus.com

# Claude AI (Anthropic)
CLAUDE_API_KEY=sk-ant-...

# DigitalOcean Spaces (S3-compatible file storage)
DO_SPACES_KEY=your_spaces_key
DO_SPACES_SECRET=your_spaces_secret
DO_SPACES_ENDPOINT=https://cap-1.digitaloceanspaces.com
DO_SPACES_BUCKET=bpo-nexus-files

# Open Banking
TRUELAYER_CLIENT_ID=your_truelayer_id
TRUELAYER_CLIENT_SECRET=your_truelayer_secret

# Twilio (WhatsApp via OpenClaw)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token

# Email (Resend)
RESEND_API_KEY=re_your_resend_key

# App
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ============================================================
# OAuth — Google & Microsoft social sign-in
# ============================================================
# Google: create credentials at https://console.cloud.google.com/apis/credentials
#   - Application type: Web application
#   - Authorized redirect URI: <OAUTH_REDIRECT_BASE_URL>/api/v1/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft: register an app at https://portal.azure.com → Azure Active Directory → App registrations
#   - Redirect URI (Web): <OAUTH_REDIRECT_BASE_URL>/api/v1/auth/microsoft/callback
#   - API permissions: Microsoft Graph → User.Read (delegated)
#   - Tenant: "common" allows any Microsoft account, or set to your tenant GUID
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT=common

# Where the providers should redirect users back to (must match what is registered
# in Google Cloud Console / Azure Portal). This is the PUBLIC URL of THIS API.
OAUTH_REDIRECT_BASE_URL=http://localhost:8000

# Where the API redirects users after a successful OAuth flow (the web app)
FRONTEND_URL=http://localhost:3000

# Secret used to sign short-lived OAuth state tokens (rotate periodically)
OAUTH_STATE_SECRET=please-change-me-to-a-long-random-string

# AWS Textract (document OCR)
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_REGION=eu-west-1

# Stripe
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
STRIPE_PRICE_STARTER=price_placeholder_starter
STRIPE_PRICE_GROWTH=price_placeholder_growth
STRIPE_PRICE_ENTERPRISE=price_placeholder_enterprise
